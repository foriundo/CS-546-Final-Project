<div class="centers-page">
  <h1>Public Computer Centers</h1>

  <form action="/centers/search" method="GET" class="center-search-form">
    <div>
      <label for="name">Search by name</label>
      <input type="text" id="name" name="name" placeholder="Enter center name">
    </div>

    <div>
      <label for="borough">Borough</label>
      <select id="borough" name="borough">
        <option value="">All Boroughs</option>
        <option value="Bronx">Bronx</option>
        <option value="Brooklyn">Brooklyn</option>
        <option value="Manhattan">Manhattan</option>
        <option value="Queens">Queens</option>
        <option value="Staten Island">Staten Island</option>
      </select>
    </div>

    <div>
      <label for="organizationName">Organization</label>
      <input type="text" id="organizationName" name="organizationName" placeholder="Enter organization name">
    </div>

    <button type="submit">Search</button>
    <a href="/centers">Clear</a>
  </form>

  {{#if centers.length}}
    <div class="centers-list">
      {{#each centers}}
        <div class="center-card">
          <h2>{{location_name}}</h2>

          <p><strong>Borough:</strong> {{borough}}</p>
          <p><strong>Address:</strong> {{full_location_address}}</p>
          <p><strong>Organization:</strong> {{operator_name}}</p>

          <a href="/centers/{{_id}}">View Details</a>
        </div>
      {{/each}}
    </div>
  {{else}}
    <p>No centers found.</p>
  {{/if}}
</div>