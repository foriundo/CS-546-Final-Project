<div class="center-detail">
  <h1>{{center.site_name}}</h1>

  <div class="center-info">
    <p><strong>Address: </strong> {{center.address}}, {{center.borough_name}}</p>
    <p><strong>Operator:</strong> {{center.operator_name}}</p>
        <p><strong>Devices Available:</strong> {{center.type_of_device_available}}</p>
        <p><strong>Hours:</strong> {{center.hours_of_operation}}</p>
      </div>

  <div class="reviews-section">
    <h2>Reviews</h2>

    {{#if reviews.length}}
      {{#each reviews}}
        <div class="review-card">
          <p><strong>{{this.userName}}</strong> — {{this.rating}}/5</p>
          <p>{{this.comment}}</p>
          {{#if (eq this.userId ../user._id)}}
            <form method="POST" action="/centers/{{../center._id}}/reviews/{{this._id}}/delete">
              <button type="submit">Delete</button>
            </form>
          {{/if}}
        </div>
      {{/each}}
    {{else}}
      <p>No reviews yet. Be the first!</p>
    {{/if}}

    {{#if user}}
      <h3>Leave a Review</h3>
      <form method="POST" action="/centers/{{center._id}}/reviews">
        <label>Rating (1–5): <input type="number" name="rating" min="1" max="5" required /></label>
        <label>Comment: <textarea name="comment" required></textarea></label>
        <button type="submit">Submit</button>
      </form>
    {{else}}
      <p><a href="/auth/login">Log in</a> to leave a review.</p>
    {{/if}}
  </div>
</div>