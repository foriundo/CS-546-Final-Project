<div class="center-detail">
  <h1>{{center.location_name}}</h1>
  
  <div class="center-info">
    <p><strong>Address: </strong> {{center.address_street}}, {{center.borough_name}}</p>
    <p><strong>Operator:</strong> {{center.operator_name}}</p>
    <p><strong>Devices Available:</strong> {{center.type_of_device_available}}</p>
    <p> <strong>Status:</strong> {{#if center.isOpen}} Open {{else}} Closed {{/if}} </p> 
    <p><strong>Hours:</strong></p>
    <div id="hours-div">
      <p><strong>Monday:</strong> {{#if center.mon_open}}{{center.mon_open}}{{else}}Unavailable{{/if}}</p>
      <p><strong>Tuesday:</strong> {{#if center.tue_open}}{{center.tue_open}}{{else}}Unavailable{{/if}}</p>
      <p><strong>Wednesday:</strong> {{#if center.wed_open}}{{center.wed_open}}{{else}}Unavailable{{/if}}</p>
      <p><strong>Thursday:</strong> {{#if center.thu_open}}{{center.thu_open}}{{else}}Unavailable{{/if}}</p>
      <p><strong>Friday:</strong> {{#if center.fri_open}}{{center.fri_open}}{{else}}Unavailable{{/if}}</p>
      <p><strong>Saturday:</strong> {{#if center.sat_open}}{{center.sat_open}}{{else}}Unavailable{{/if}}</p>
      <p><strong>Sunday:</strong> {{#if center.sun_open}}{{center.sun_open}}{{else}}Unavailable{{/if}}</p>
    </div>
  </div>

  <div class="favorites-section">
    {{#if user}}
      <button id="fav-btn" data-center-id="{{center._id}}">{{#if isFavorited}}Remove from Favorites{{else}}Add to favorites{{/if}}</button>
    {{else}}
      <p><a href="/auth/login">Log in</a> to add this center to your favorites!</p>
    {{/if}}
  </div>

  <div class="reviews-section">
    <h2>Reviews</h2>

    {{#if centerReviews.length}}
      {{#each centerReviews}}
        <div class="review-card">
          <p><strong>{{this.userName}}</strong> — {{this.rating}}/5</p>
          <p>{{this.comment}}</p>
          {{#if (eq this.userId ../user._id)}}
            <form method="POST" action="/centers/{{../center._id}}/reviews/{{this._id}}/delete">
              <button type="submit">Delete</button>
            </form>
          {{/if}}
        </div>
      {{/each}}
    {{else}}
      <p>No reviews yet. Be the first!</p>
    {{/if}}

    {{#if user}}
      <h3>Leave a Review</h3>
      <form method="POST" action="/centers/{{center._id}}/reviews">
        <label>Rating (1–5): <input type="number" name="rating" min="1" max="5" required /></label>
        <label>Comment: <textarea name="comment" required></textarea></label>
        <button type="submit">Submit</button>
      </form>
    {{else}}
      <p><a href="/auth/login">Log in</a> to leave a review.</p>
    {{/if}}
  </div>

  <div class="reports-section">
    <h2>Reports</h2>

    {{#if user}}
      <h3>Report an Issue</h3>

      <form id="report-form">
        <input type="hidden" id="center-id" value="{{center._id}}">
        <label for="issue-types">Issue Type:</label>
        <select id="issue-types" name="issueType" required>
          <option value="incorrect hours">Incorrect Hours</option>
          <option value="incorrect address">Incorrect Address</option>
          <option value="other">Other Issue</option>
        </select>

        <label for="issue">Issue:</label>
        <textarea id="issue" name="description" required></textarea>

        <button type="submit">Submit</button>
      </form>

      <div id="report-success-failure"></div>
    {{else}}
      <p><a href="/auth/login">Log in</a> to report an issue.</p>
    {{/if}}

  </div>
</div>